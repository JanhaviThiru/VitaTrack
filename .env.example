# -------------------------
# Backend (Spring Boot) environment
# Copy to .env (or set in your shell/hosting platform)
# -------------------------

SERVER_PORT=8081

# Supabase/Postgres connection
# Example for local Postgres:
# DB_URL=jdbc:postgresql://localhost:5432/vitatrack
# Example for Supabase (pooler):
# DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/vitatrack
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
APP_JWT_SECRET=replace-with-a-very-long-random-secret-key
APP_JWT_EXPIRATION_MS=86400000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_HEADERS=*
APP_CORS_ALLOW_CREDENTIALS=true
